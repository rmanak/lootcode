{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/pip install:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m uvicorn:*)",
      "Bash(uvicorn:*)",
      "Bash(pytest:*)",
      "Bash(python scripts/seed.py)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./*.db)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  }
}
