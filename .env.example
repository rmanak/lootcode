# Copy to `.env` and adjust. Everything has a sane default for local use.

# ── Server ──────────────────────────────────────────────────────────────
# 0.0.0.0 makes it reachable from other devices on your home network.
HOST=0.0.0.0
PORT=8000

# ── Database ────────────────────────────────────────────────────────────
# SQLite file path. Default is ./lootcode.db in the project root.
# LOOTCODE_DB=/absolute/path/to/lootcode.db

# ── Code executor ───────────────────────────────────────────────────────
# subprocess = zero-dependency, resource-limited local runner (default).
# docker     = stronger isolation (needs Docker + the lootcode-runner image).
EXECUTOR_BACKEND=subprocess
EXEC_TIME_LIMIT_MS=10000
EXEC_MEMORY_LIMIT_MB=512
EXEC_MAX_OUTPUT_KB=64

# ── AI problem generation (optional) ────────────────────────────────────
# Leave blank to disable the admin "Generate with AI" feature.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
